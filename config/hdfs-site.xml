<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet type="text/xsl" href="configuration.xsl"?>
<!--
  hdfs-site.xml
  HDFS Storage Configuration
  Cluster: 3-node AWS EC2 t3.small
  Replication: 2 (across slave1 and slave2)
  Author: Your Name
-->
<configuration>

    <!-- Number of times each block is replicated across DataNodes -->
    <property>
        <n>dfs.replication</n>
        <value>2</value>
        <description>Data replication factor. Set to 2 for 2 slave nodes.</description>
    </property>

    <!-- NameNode storage directory -->
    <property>
        <n>dfs.namenode.name.dir</n>
        <value>/home/hduser/hadoopdata/namenode</value>
        <description>Directory where NameNode stores namespace and transaction logs.</description>
    </property>

    <!-- DataNode storage directory -->
    <property>
        <n>dfs.datanode.data.dir</n>
        <value>/home/hduser/hadoopdata/datanode</value>
        <description>Directory where DataNode stores its blocks.</description>
    </property>

</configuration>
